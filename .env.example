# Copiez ce fichier en `.env` et renseignez vos valeurs.
# Ces variables sont injectées au build (préfixe VITE_ obligatoire).

# Formulaire de contact — identifiant de formulaire Formspree (https://formspree.io)
# Exemple : xdorwkey  (l'URL devient https://formspree.io/f/xdorwkey)
VITE_FORMSPREE_ID=

# Planification de démo — lien Calendly (https://calendly.com)
# Exemple : https://calendly.com/votre-compte/demo-bxchange
VITE_CALENDLY_URL=
